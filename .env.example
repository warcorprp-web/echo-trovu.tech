# Upstream API Configuration
UPSTREAM_API_URL=https://api.openai.com/v1
UPSTREAM_API_KEY=your_api_key_here

# Cache Settings
CACHE_THRESHOLD=0.88    # Semantic similarity threshold (0.70-0.95)
                        # 0.88 = conservative (fewer false positives)
                        # 0.70 = aggressive (more savings, some errors)
CACHE_TTL=86400         # 24 hours
ENABLE_SEMANTIC=true

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
